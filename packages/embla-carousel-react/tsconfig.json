{
  "compilerOptions": {
    "target": "ES2015",
    "module": "esnext",
    "lib": ["dom", "esnext"],
    "esModuleInterop": true,
    "strict": true,
    "declaration": true,
    "declarationDir": "./",
    "rootDir": "./src",
    "moduleResolution": "bundler",
    "jsx": "react",
    "types": ["jest", "node"]
  },
  "include": ["src/index.ts", "src/components", "src/__tests__"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
